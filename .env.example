# Copy to `.env` and fill in your values. `.env` is gitignored.

# Required: Azure SQL Server hostname
MCP_DB_SERVER=your-server.database.windows.net

# Required: Database name
MCP_DB_DATABASE=your-database-name

# Optional: ODBC driver name (default: ODBC Driver 18 for SQL Server)
# MCP_DB_DRIVER=ODBC Driver 18 for SQL Server

# Optional: log level (default: INFO)
# MCP_DB_LOG_LEVEL=INFO
